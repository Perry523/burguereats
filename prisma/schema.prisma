generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  city      String?
  state     String?
  zipCode   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  admins         Admins[]
  dishes         Dish[]
  sideCategories SideCategory[]
  categories     Category[]
}

model Admins {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Dish {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  category    String
  image       String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId      String
  company        Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sideCategories DishSideCategory[]
  categories     DishCategory[]

  @@index([companyId])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  dishes DishCategory[]

  @@unique([companyId, slug])
  @@index([companyId])
}

model DishCategory {
  dishId     String
  categoryId String
  createdAt  DateTime @default(now())

  dish     Dish     @relation(fields: [dishId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([dishId, categoryId])
  @@index([categoryId])
}

model SideCategory {
  id            String   @id @default(cuid())
  name          String
  description   String?
  isRequired    Boolean  @default(false)
  maxSelections Int?
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  sides  SideOption[]
  dishes DishSideCategory[]

  @@index([companyId])
}

model SideOption {
  id             String   @id @default(cuid())
  name           String
  description    String?
  priceIncrement Float    @default(0)
  image          String?
  isAvailable    Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categoryId String
  category   SideCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model DishSideCategory {
  dishId         String
  sideCategoryId String
  order          Int    @default(0)

  dish         Dish         @relation(fields: [dishId], references: [id], onDelete: Cascade)
  sideCategory SideCategory @relation(fields: [sideCategoryId], references: [id], onDelete: Cascade)

  @@id([dishId, sideCategoryId])
  @@index([sideCategoryId])
}
